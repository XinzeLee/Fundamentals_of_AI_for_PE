Plecs {
  Name          "DAB_sample1"
  Version       "4.7"
  CircuitModel  "DiscStateSpace"
  StartTime     "0"
  TimeSpan      "Tstop"
  Timeout       ""
  Solver        "FixedStepDiscrete"
  MaxStep       "1e-7"
  InitStep      "-1"
  FixedStep     "1e-7"
  Refine        "1"
  ZCStepSize    "1e-9"
  RelTol        "1e-2"
  AbsTol        "-1"
  TurnOnThreshold "0"
  SyncFixedStepTasks "2"
  UseSingleCommonBaseRate "2"
  LossVariableLimitExceededMsg "2"
  NegativeSwitchLossMsg "1"
  DivisionByZeroMsg "2"
  StiffnessDetectionMsg "1"
  MaxConsecutiveZCs "1000"
  AlgebraicLoopWithStateMachineMsg "2"
  AssertionAction "1"
  InitializationCommands "%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%"
"%%\n% Author: Xinze Li %\n%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%"
"%%%\n\nTstop = 0.06;\n\n%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%"
"%\n% comment out codes below, these are passed from python script\n%%%%%%%%%%"
"%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%% \n% D1 = 1;\t\t\t%change from py"
"thon\n% D2 = 1;\t\t\t%change from python\n% P = 600;\t\t%change from python\n"
"% Vref = 200;\t%change from python\n% Ro = Vref^2/P;\t%change from python\t\t"
"% load resistance (ohms)\n\n%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%"
"%%%%%\n%Basic Operating Conditions%\n%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%"
"%%%%%%%%%%%%%%\nfs = 50e3;               \t% switching frequency (Hz)\nTs = 1"
"/fs;\t\t\t\t\t\t% switching period\nTdead = 200e-9;\t\t\t\t% dead time\nVin ="
" 200;             \t\t% input voltage (V)\n\n%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%"
"%%%%%%%%%%%%%%%%%%%%%%\n%Circuit Parameters%\n%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%"
"%%%%%%%%%%%%%%%%%%%%%%%\nLr = 50e-6;            \t% leakage inductance (H)\nR"
"L = 12e-3;\t\t\t\t\t% equivalent resistance of inductor (Ohm)\n% Lm = 2e-3;\t"
"\t\t\t\t% magnetizing inductance (H)\nCf = 160e-6;            \t% output capa"
"citance (F)\nCf_esr = 12e-3;\t\t   \t% output capacitance ESR (ohms)\n\n%%%%%"
"%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%\n% Discrete PI controller %"
"\n%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%\nKp = 0.01;\nKi = 1;"
"\nPI_Upper = 0.5;\nPI_Lower = -0.5;\nfc = fs;\n\n%%%%%%%%%%%%%%%%%%%%%%%%%%%%"
"%%%%%%%%%%%%%%%%%%%%%%%%%%\n%Payton T250-4-16 transformer, material: TP4A%\n%"
"%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%\nN_pri = 32;     \t% nu"
"mber of turns on the primary side\nN_sec = 32;     \t% number of turns on the"
" secondary side\nAe = 306e-6;    \t% cross-sectional area (m^2)\nLe = 152e-3;"
"     \t% length of flux path (m)\nVe = 46500e-9;\nkc = 32.3;\nafa = 1.2844;\n"
"beta = 2.7707;\nBsat = 440e-3; \t% saturation magnetic flux denisty (T)\nHsat"
" = 175;   \t\t% saturation magnetic field strength (A/m)\nHc = 13;\nBr = 0.15"
";\nu0 = 4*pi*1e-7; \t% permeability of free space (m*kg*s^-2*A^-2)\n%ur_init "
"= 2400; \t% unsaturated relative permeability\nur_sat = 10;     \t% saturated"
" relative permeability - tangential slope of the BH curve at Hsat\n\n%%%%%%%%"
"%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%\n%MOSFET: C2M0080120D%\n%%%%%%"
"%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%\nRgoff = 10;\nRgon = 10.4;\n"
"Ron_MOSFET = 98e-3;             \t\t\t% MOSFET on resistance (ohms)\nVf_Diode"
" = 3.3; \t       \t\t\t\t\t% diode forward voltage (V)\nRon_Diode = 10e-3;\t"
"\t\t\t\t\t\t% diode on resistance (ohms)\nT_init = 25;\t\t\t\t\t       \t\t% "
"initial temperature (C)"
  InitialState  "1"
  SystemState   ""
  TaskingMode   "1"
